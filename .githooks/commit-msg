#!/bin/sh
MSG_FILE="$1"
MSG="$(cat "$MSG_FILE")"

# Require: <PROJECT>-123: description  (PROJECT = HH or LGA — both live in this repo)
PATTERN='^(HH|LGA)-[0-9]+: .+'

# Allow merge commits
if echo "$MSG" | grep -Eq '^Merge '; then
  exit 0
fi

if echo "$MSG" | grep -Eq "$PATTERN"; then
  exit 0
fi

echo ""
echo "❌ Commit rejected."
echo "Required format:"
echo "  <PROJECT>-<number>: <description>   (PROJECT = HH or LGA)"
echo ""
echo "Examples:"
echo "  HH-102: fix enrollment validation bug"
echo "  LGA-23: pre-generate Polly word timings"
echo ""
exit 1